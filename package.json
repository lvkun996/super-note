{
  "name": "super-note",
  "version": "0.1.5",
  "private": true,
  "description": "认识自身平凡后，依旧拥有改变世界的勇气",
  "author": "kunkun",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "cache:packager": "node scripts/cache-packager-deps.mjs",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "pack": "npm run cache:packager && npm run build && electron-builder --dir",
    "dist": "npm run cache:packager && npm run build && electron-builder",
    "dist:win7-8": "npm run cache:packager && npm run build && electron-builder --config electron-builder.win7-8.json --publish never"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "antd": "^5.24.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.supernote.desktop",
    "productName": "Super Note",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "artifactName": "Super.Note.Setup.${version}.${ext}",
      "icon": "assets/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
